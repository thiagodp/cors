{
    "name": "phputil/cors",
    "description": "CORS middleware for phputil/router",
    "type": "library",
    "license": "MIT",
    "scripts": {
        "test": "kahlan --cc=1",
        "test2": "kahlan --reporter=verbose",
        "cov": "kahlan --coverage",
        "check": "phpstan analyze src",
        "dep": "composer depends php",
        "migrate": "rector"
    },
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "ext-curl": "*",
        "symfony/http-client": "^5.4",
        "phputil/router": "^0.3.3",
        "phpstan/phpstan": "^0.12.100",
        "rector/rector": "^0.8.56",
        "kahlan/kahlan": "^6.1"
    },
    "autoload": {
        "psr-4": {
            "phputil\\cors\\": "src/"
        },
        "files": [
            "src/cors.php"
        ]
    }
}
